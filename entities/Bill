{
  "name": "Bill",
  "type": "object",
  "properties": {
    "bill_number": {
      "type": "string",
      "description": "Bill identifier (e.g., HB 1234, SB 567)"
    },
    "public_act_number": {
      "type": "string",
      "description": "Public Act number if passed"
    },
    "originating_chamber": {
      "type": "string",
      "enum": [
        "Senate",
        "House"
      ],
      "description": "Chamber where bill originated"
    },
    "sponsors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of bill sponsors"
    },
    "sponsor_emails": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Email addresses of sponsors for permission checking"
    },
    "short_title": {
      "type": "string",
      "description": "Brief title of the bill"
    },
    "long_title": {
      "type": "string",
      "description": "Full official title"
    },
    "status": {
      "type": "string",
      "enum": [
        "Introduced",
        "In Committee",
        "Passed Chamber",
        "In Other Chamber",
        "Passed Legislature",
        "Signed into Law",
        "Vetoed",
        "Died"
      ],
      "description": "Current status of the bill"
    },
    "introduction_date": {
      "type": "string",
      "format": "date"
    },
    "last_action_date": {
      "type": "string",
      "format": "date"
    },
    "summary": {
      "type": "string",
      "description": "Bill summary"
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "description": "Associated PDFs and documents"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "chamber": {
            "type": "string"
          }
        }
      },
      "description": "Bill history timeline"
    },
    "session": {
      "type": "string",
      "description": "Legislative session (e.g., 2024-2025)"
    }
  },
  "required": [
    "bill_number",
    "short_title",
    "status",
    "originating_chamber"
  ]
}