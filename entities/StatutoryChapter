{
  "name": "StatutoryChapter",
  "type": "object",
  "properties": {
    "title_number": {
      "type": "number",
      "description": "Parent title number"
    },
    "chapter_number": {
      "type": "number",
      "description": "Chapter number within title"
    },
    "full_chapter_code": {
      "type": "string",
      "description": "Combined code (e.g., 307 for Title 3 Chapter 7)"
    },
    "name": {
      "type": "string",
      "description": "Chapter name"
    }
  },
  "required": [
    "title_number",
    "chapter_number",
    "full_chapter_code",
    "name"
  ]
}